package com.example.myapplication;

import android.os.Bundle;
import android.widget.Button;
import android.widget.TextView;

import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    TextView tvResult;
    String input = "";

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        tvResult = findViewById(R.id.tvResult);

        int[] nums = {
                R.id.btn0, R.id.btn1, R.id.btn2, R.id.btn3,
                R.id.btn4, R.id.btn5, R.id.btn6, R.id.btn7,
                R.id.btn8, R.id.btn9, R.id.btnDot
        };

        for (int id : nums) {
            findViewById(id).setOnClickListener(v -> {
                Button b = (Button) v;
                input += b.getText().toString();
                tvResult.setText(input);
            });
        }

        findViewById(R.id.btnPlus).setOnClickListener(v -> add("+"));
        findViewById(R.id.btnMinus).setOnClickListener(v -> add("-"));
        findViewById(R.id.btnMultiply).setOnClickListener(v -> add("*"));
        findViewById(R.id.btnDivide).setOnClickListener(v -> add("/"));
        findViewById(R.id.btnOpen).setOnClickListener(v -> add("("));
        findViewById(R.id.btnClose).setOnClickListener(v -> add(")"));

        findViewById(R.id.btnClear).setOnClickListener(v -> {
            input = "";
            tvResult.setText("0");
        });

        findViewById(R.id.btnEqual).setOnClickListener(v -> {
            try {
                double result = eval(input);
                tvResult.setText(String.valueOf(result));
                input = String.valueOf(result);
            } catch (Exception e) {
                tvResult.setText("Error");
                input = "";
            }
        });
    }

    void add(String v) {
        input += v;
        tvResult.setText(input);
    }

    public double eval(String str) {
        return new Object() {
            int pos = -1, ch;

            void nextChar() {
                ch = (++pos < str.length()) ? str.charAt(pos) : -1;
            }

            double parse() {
                nextChar();
                return parseExpression();
            }

            double parseExpression() {
                double x = parseTerm();
                while (true) {
                    if (ch == '+') { nextChar(); x += parseTerm(); }
                    else if (ch == '-') { nextChar(); x -= parseTerm(); }
                    else return x;
                }
            }

            double parseTerm() {
                double x = parseFactor();
                while (true) {
                    if (ch == '*') { nextChar(); x *= parseFactor(); }
                    else if (ch == '/') { nextChar(); x /= parseFactor(); }
                    else return x;
                }
            }

            double parseFactor() {
                StringBuilder sb = new StringBuilder();

                while ((ch >= '0' && ch <= '9') || ch == '.') {
                    sb.append((char) ch);
                    nextChar();
                }
                return Double.parseDouble(sb.toString());
            }
        }.parse();
    }
}
